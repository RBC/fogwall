[0.294, "o", "==> Granting collaborator access...\r\n"]
[0.299, "o", "==> Tokens written to docker/../test/gitea/tokens.env\r\n\r\n"]
[0.000, "o", "==> Setup complete!\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "    Gitea UI:  http://localhost:3000  (fogwalladmin / Admin1234!)\r\n\r\n"]
[0.000, "o", "    Users:\r\n"]
[0.000, "o", "      test-user         password: Test1234!\r\n"]
[0.000, "o", "      user2             password: Test1234!\r\n"]
[0.000, "o", "      user3             password: Test1234!\r\n\r\n"]
[0.000, "o", "    Repos (allowed):\r\n"]
[0.000, "o", "      test-owner/test-repo         вҖ” test-user (LITERAL) + user3 (REGEX)\r\n"]
[0.000, "o", "      test-owner/test-repo-2       вҖ” user3 (REGEX) only\r\n"]
[0.000, "o", "      otherorg/other-foo           вҖ” user2 (GLOB)\r\n"]
[0.000, "o", "      otherorg/other-bar           вҖ” user2 (GLOB)\r\n"]
[0.000, "o", "    Repos (deny-rule targets):\r\n"]
[0.000, "o", "      test-owner/test-repo-readonly  вҖ” blocked: name matches *-readonly\r\n"]
[0.000, "o", "      otherorg/other-secret      вҖ” blocked: slug deny on /otherorg/other-secret\r\n\r\n"]
[0.000, "o", "    Tokens written to: docker/../test/gitea/tokens.env\r\n"]
[0.000, "o", "    Source before running smoke tests:\r\n"]
[0.001, "o", "      source test/gitea/tokens.env\r\n"]
[0.000, "o", "\r\n"]
[0.000, "o", "    fogwall push path:  http://localhost:8080/push/gitea:3000/test-owner/test-repo.git\r\n"]
[0.000, "o", "    fogwall proxy path: http://localhost:8080/proxy/gitea:3000/test-owner/test-repo.git\r\n"]
[0.001, "o", "+ FOGWALL_PROVIDERS_GITEA_URI=http://localhost:3000\r\n+ ./gradlew :fogwall-dashboard:run\r\n"]
