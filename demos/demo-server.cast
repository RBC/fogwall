[0.018, "o", "==> Creating user 'test-user'...\r\n"]
[0.297, "o", "New user 'test-user' has been successfully created!\r\n"]
[0.016, "o", "==> Creating user 'user2'...\r\n"]
[0.287, "o", "New user 'user2' has been successfully created!\r\n"]
[0.017, "o", "==> Creating user 'user3'...\r\n"]
[0.301, "o", "New user 'user3' has been successfully created!\r\n"]
[0.019, "o", "==> Generating tokens...\r\n"]
[1.729, "o", "==> Creating org 'test-owner'...\r\n"]
[0.053, "o", "==> Creating org 'otherorg'...\r\n"]
[0.047, "o", "==> Creating repo 'test-owner/test-repo'...\r\n"]
[0.308, "o", "==> Creating repo 'test-owner/test-repo-2'...\r\n"]
[0.293, "o", "==> Creating repo 'test-owner/test-repo-readonly'...\r\n"]
[0.292, "o", "==> Creating repo 'otherorg/other-foo'...\r\n"]
[0.329, "o", "==> Creating repo 'otherorg/other-bar'...\r\n"]
